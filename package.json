{
  "name": "gamenotebook",
  "private": true,
  "version": "0.2.2",
  "packageManager": "pnpm@7.33.7",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test:basic": "node -r esbuild-register scripts/basic-regression-tests.ts",
    "check:release-workflow": "node scripts/check-tag-release-workflow.cjs --strict",
    "tauri": "tauri",
    "dev:live": "CARGO_TARGET_DIR=/tmp/gamenotebook-dev-target npx -y pnpm@7 tauri dev",
    "dev:tauri": "pnpm dev:live",
    "build:mac:app": "node -r esbuild-register ./scripts/build-mac-app.ts",
    "build:release": "node ./scripts/build-release-artifacts.cjs",
    "build:release:macos": "pnpm build:release -- --platform macos",
    "build:release:windows": "pnpm build:release -- --platform windows",
    "build:release:linux": "pnpm build:release -- --platform linux",
    "release": "pnpm build:release"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.3.0",
    "@codemirror/lang-cpp": "^6.0.2",
    "@codemirror/lang-css": "^6.0.1",
    "@codemirror/lang-html": "^6.1.2",
    "@codemirror/lang-java": "^6.0.0",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-markdown": "^6.0.3",
    "@codemirror/lang-php": "^6.0.0",
    "@codemirror/lang-python": "^6.0.4",
    "@codemirror/lang-rust": "^6.0.1",
    "@codemirror/lang-sql": "^6.3.0",
    "@codemirror/lang-xml": "^6.0.1",
    "@codemirror/language": "^6.3.0",
    "@codemirror/legacy-modes": "^6.2.0",
    "@codemirror/state": "^6.1.2",
    "@floating-ui/dom": "^1.0.3",
    "@lezer/highlight": "^1.2.3",
    "@preact/signals": "^1.1.2",
    "@sentry/browser": "^7.17.3",
    "@sentry/tracing": "^7.17.3",
    "@solidjs/router": "^0.5.0",
    "@tauri-apps/api": "^1.2.0",
    "@uiw/codemirror-theme-github": "^4.12.4",
    "blockly": "^12.4.1",
    "codemirror": "^6.0.1",
    "dayjs": "^1.11.6",
    "nanoid": "^4.0.0",
    "solid-floating-ui": "^0.1.0",
    "solid-js": "^1.6.0",
    "tippy.js": "^6.3.7"
  },
  "devDependencies": {
    "@codemirror/lang-javascript": "^6.1.1",
    "@iconify/json": "^2.1.130",
    "@tauri-apps/cli": "^1.2.0",
    "@types/node": "^18.7.10",
    "@vitejs/plugin-react": "^2.0.0",
    "autoprefixer": "^10.4.12",
    "esbuild": "^0.15.12",
    "esbuild-register": "^3.3.3",
    "tailwindcss": "^3.2.1",
    "tailwindcss-animate": "^1.0.5",
    "typescript": "^4.6.4",
    "unocss": "^0.46.1",
    "vite": "^3.0.2",
    "vite-plugin-solid": "^2.3.10"
  }
}
