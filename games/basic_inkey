CLS
X=15
Y=14
LOCATE 0,0
COLOR 15,0
PRINT "WASD MOVE, Q QUIT"
COLOR 7,0
LOCATE X,Y
PRINT "@";
OLDX=X
OLDY=Y
K$=INKEY$
IF K$="a" THEN X=X-1
IF K$="d" THEN X=X+1
IF K$="w" THEN Y=Y-1
IF K$="s" THEN Y=Y+1
IF K$="q" THEN END
IF X<0 THEN X=0
IF X>31 THEN X=31
IF Y<1 THEN Y=1
IF Y>29 THEN Y=29
IF X<>OLDX OR Y<>OLDY THEN LOCATE OLDX,OLDY
IF X<>OLDX OR Y<>OLDY THEN PRINT " ";
GOTO
